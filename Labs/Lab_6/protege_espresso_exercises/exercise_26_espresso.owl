<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
  xmlns:owl="http://www.w3.org/2002/07/owl#"
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
>
  <owl:Class rdf:about="http://example.org/espresso#Cafe">
    <rdfs:label>Café</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/espresso#EspressoBase"/>
  </owl:Class>
  <owl:Ontology rdf:about="http://example.org/espresso#EspressoOntology">
    <rdfs:comment>Espresso ontology for Semantic Web Lab 6, exercise/step 26.</rdfs:comment>
    <rdfs:comment>Exercise 11 answer: transitive means if A hasIngredient B and B hasIngredient C, then A hasIngredient C.</rdfs:comment>
    <rdfs:comment>Exercise 12 answer: functional means an individual can have at most one value for this property.</rdfs:comment>
    <rdfs:comment>Exercise 14 answer: a restriction is a class expression that limits or describes property values for members of a class.</rdfs:comment>
    <rdfs:comment>Exercise 19: ontology is ready to classify with a Description Logic reasoner.</rdfs:comment>
    <rdfs:comment>Exercise 22: CafeMocha is converted to a defined class using equivalentClass.</rdfs:comment>
    <rdfs:comment>Exercise 23 answer: after reasoning, classes that satisfy the definition of CafeMocha can be inferred as CafeMocha.</rdfs:comment>
    <rdfs:comment>Exercise 25 answer: EspressoMachiato should be inferred as a subclass of SweetEspresso. hasSweetness is functional because each espresso should have one sweetness level.</rdfs:comment>
  </owl:Ontology>
  <owl:Class rdf:about="http://example.org/espresso#EspressoMachiato">
    <rdfs:subClassOf rdf:resource="http://example.org/espresso#EspressoSpecialty"/>
    <rdfs:subClassOf>
      <owl:Restriction rdf:nodeID="N357ca52d2af0466b97c73eba54b9e46f">
        <owl:onProperty rdf:resource="http://example.org/espresso#hasSweetness"/>
        <owl:someValuesFrom rdf:resource="http://example.org/espresso#ExtraSweetness"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/espresso#InterestingEspresso">
    <rdfs:subClassOf rdf:resource="http://example.org/espresso#Espresso"/>
    <owl:equivalentClass>
      <owl:Class rdf:nodeID="Nb569961150bf4a1883a2b55d5da3d8f8">
        <owl:intersectionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://example.org/espresso#Espresso"/>
          <owl:Restriction rdf:nodeID="N8c83232cfcd14b399bbc6c34e2b85732">
            <owl:onProperty>
              <owl:ObjectProperty rdf:about="http://example.org/espresso#hasTopping">
                <rdfs:subPropertyOf rdf:resource="http://example.org/espresso#hasIngredient"/>
                <owl:inverseOf rdf:resource="http://example.org/espresso#isToppingOf"/>
                <rdfs:domain rdf:resource="http://example.org/espresso#Espresso"/>
                <rdfs:range rdf:resource="http://example.org/espresso#EspressoTopping"/>
              </owl:ObjectProperty>
            </owl:onProperty>
            <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">3</owl:minQualifiedCardinality>
            <owl:onClass rdf:resource="http://example.org/espresso#EspressoTopping"/>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/espresso#SweetEspresso">
    <rdfs:subClassOf rdf:resource="http://example.org/espresso#Espresso"/>
    <owl:equivalentClass>
      <owl:Class rdf:nodeID="Ne0d4746309cf45d1a0b9c1fd8dc42032">
        <owl:intersectionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://example.org/espresso#Espresso"/>
          <owl:Restriction rdf:nodeID="Nb2126b80e82a4946aba9f1b6a74ad28c">
            <owl:onProperty>
              <owl:ObjectProperty rdf:about="http://example.org/espresso#hasSweetness">
                <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
                <rdfs:range rdf:resource="http://example.org/espresso#EspressoSweetness"/>
              </owl:ObjectProperty>
            </owl:onProperty>
            <owl:someValuesFrom rdf:resource="http://example.org/espresso#ExtraSweetness"/>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/espresso#EspressoRoast">
    <rdfs:subClassOf rdf:resource="http://example.org/espresso#EspressoBase"/>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/espresso#ProbeClass">
    <rdfs:comment>Repaired: no longer a subclass of two disjoint topping classes.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/espresso#EspressoTopping"/>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/espresso#CinnamonDolceLatte">
    <rdfs:subClassOf rdf:resource="http://example.org/espresso#EspressoSpecialty"/>
    <rdfs:subClassOf>
      <owl:Restriction rdf:nodeID="N6e03f230a1814d7a8208937e669b5d7b">
        <owl:onProperty rdf:resource="http://example.org/espresso#hasTopping"/>
        <owl:someValuesFrom rdf:resource="http://example.org/espresso#CinnamonTopping"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction rdf:nodeID="N8f892e9a183e429e9521e6747fa0cef6">
        <owl:onProperty rdf:resource="http://example.org/espresso#hasTopping"/>
        <owl:someValuesFrom rdf:resource="http://example.org/espresso#WhippedCreamTopping"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment>Espresso with steamed milk and cinnamon dolce flavored syrup.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/espresso#CafeMocha">
    <rdfs:subClassOf rdf:resource="http://example.org/espresso#EspressoSpecialty"/>
    <rdfs:subClassOf>
      <owl:Restriction rdf:nodeID="N26162df028804c94b775e8b6bdc1b89c">
        <owl:onProperty rdf:resource="http://example.org/espresso#hasTopping"/>
        <owl:someValuesFrom rdf:resource="http://example.org/espresso#WhippedCreamTopping"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <owl:equivalentClass>
      <owl:Class rdf:nodeID="N20f2152e3239473e8ecc0a01cb75ae00">
        <owl:intersectionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://example.org/espresso#EspressoSpecialty"/>
          <owl:Restriction rdf:nodeID="N11277c5ad20e44388be8bb18f9e71e1b">
            <owl:onProperty rdf:resource="http://example.org/espresso#hasTopping"/>
            <owl:someValuesFrom rdf:resource="http://example.org/espresso#WhippedCreamTopping"/>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/espresso#FoamOrClassicSpecialty">
    <rdfs:subClassOf rdf:resource="http://example.org/espresso#EspressoSpecialty"/>
    <owl:equivalentClass>
      <owl:Class rdf:nodeID="N28e1cdf47a8f4209820a2901c3456ddf">
        <owl:intersectionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://example.org/espresso#EspressoSpecialty"/>
          <owl:Restriction rdf:nodeID="Nf66c3b3719bb4da18d09ab0cb772b14d">
            <owl:onProperty rdf:resource="http://example.org/espresso#hasTopping"/>
            <owl:allValuesFrom>
              <owl:Class rdf:nodeID="Nd51ffd8562d742d28ec8cc056d23c8a6">
                <owl:unionOf rdf:parseType="Collection">
                  <rdf:Description rdf:about="http://example.org/espresso#FoamTopping"/>
                  <rdf:Description rdf:about="http://example.org/espresso#ClassicWhippedCreamTopping"/>
                </owl:unionOf>
              </owl:Class>
            </owl:allValuesFrom>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/espresso#Cappucino">
    <rdfs:subClassOf rdf:resource="http://example.org/espresso#EspressoBase"/>
  </owl:Class>
  <owl:ObjectProperty rdf:about="http://example.org/espresso#hasIngredient">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="http://example.org/espresso#isIngredientOf"/>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:Class rdf:about="http://example.org/espresso#EspressoSweetness">
    <owl:equivalentClass>
      <owl:Class rdf:nodeID="Ncc71cf44d0b042c7a3fd432aeb2bce2d">
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://example.org/espresso#NoneSweetness"/>
          <rdf:Description rdf:about="http://example.org/espresso#MediumSweetness"/>
          <rdf:Description rdf:about="http://example.org/espresso#ExtraSweetness"/>
        </owl:unionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/espresso#FoamTopping">
    <rdfs:subClassOf rdf:resource="http://example.org/espresso#EspressoTopping"/>
    <owl:disjointWith rdf:resource="http://example.org/espresso#WhippedCreamTopping"/>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/espresso#CinnamonTopping">
    <rdfs:subClassOf rdf:resource="http://example.org/espresso#EspressoTopping"/>
    <owl:disjointWith rdf:resource="http://example.org/espresso#FoamTopping"/>
    <owl:disjointWith rdf:resource="http://example.org/espresso#WhippedCreamTopping"/>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/espresso#VegetableWhippedCreamTopping">
    <rdfs:subClassOf rdf:resource="http://example.org/espresso#WhippedCreamTopping"/>
    <owl:disjointWith rdf:resource="http://example.org/espresso#SweetenedWhippedCreamTopping"/>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/espresso#NoneSweetness">
    <rdfs:subClassOf rdf:resource="http://example.org/espresso#EspressoSweetness"/>
    <owl:disjointWith rdf:resource="http://example.org/espresso#MediumSweetness"/>
    <owl:disjointWith rdf:resource="http://example.org/espresso#ExtraSweetness"/>
  </owl:Class>
  <owl:ObjectProperty rdf:about="http://example.org/espresso#hasBase">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://example.org/espresso#hasIngredient"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="http://example.org/espresso#isBaseOf"/>
    </owl:inverseOf>
    <rdfs:domain rdf:resource="http://example.org/espresso#Espresso"/>
    <rdfs:range rdf:resource="http://example.org/espresso#EspressoBase"/>
  </owl:ObjectProperty>
  <owl:Class rdf:about="http://example.org/espresso#ClassicWhippedCreamTopping">
    <rdfs:subClassOf rdf:resource="http://example.org/espresso#WhippedCreamTopping"/>
    <owl:disjointWith rdf:resource="http://example.org/espresso#VegetableWhippedCreamTopping"/>
    <owl:disjointWith rdf:resource="http://example.org/espresso#SweetenedWhippedCreamTopping"/>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/espresso#EspressoSpecialty">
    <rdfs:subClassOf rdf:resource="http://example.org/espresso#Espresso"/>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/espresso#WhippedCreamTopping">
    <rdfs:subClassOf rdf:resource="http://example.org/espresso#EspressoTopping"/>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/espresso#Espresso">
    <owl:disjointWith rdf:resource="http://example.org/espresso#EspressoBase"/>
    <owl:disjointWith rdf:resource="http://example.org/espresso#EspressoTopping"/>
    <rdfs:subClassOf>
      <owl:Restriction rdf:nodeID="N4fde98e966c64942bbde9c413c1728b4">
        <owl:onProperty rdf:resource="http://example.org/espresso#hasBase"/>
        <owl:someValuesFrom rdf:resource="http://example.org/espresso#EspressoBase"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/espresso#ExtraSweetness">
    <rdfs:subClassOf rdf:resource="http://example.org/espresso#EspressoSweetness"/>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/espresso#EspressoTopping"/>
  <owl:Class rdf:about="http://example.org/espresso#EspressoBase">
    <owl:disjointWith rdf:resource="http://example.org/espresso#EspressoTopping"/>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/espresso#SweetenedWhippedCreamTopping">
    <rdfs:subClassOf rdf:resource="http://example.org/espresso#WhippedCreamTopping"/>
  </owl:Class>
  <owl:ObjectProperty rdf:about="http://example.org/espresso#isToppingOf"/>
  <owl:Class rdf:about="http://example.org/espresso#MediumSweetness">
    <rdfs:subClassOf rdf:resource="http://example.org/espresso#EspressoSweetness"/>
    <owl:disjointWith rdf:resource="http://example.org/espresso#ExtraSweetness"/>
  </owl:Class>
</rdf:RDF>
